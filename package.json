{
  "name": "slack-release-bot",
  "version": "1.0.0",
  "description": "Slack Release Bot",
  "main": "handler.js",
  "scripts": {
    "start": "NODE_OPTIONS=--enable-source-maps && node app.js",
    "test": "echo \"Error: no test specified\" && exit 1",
