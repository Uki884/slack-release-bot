  "license": "MIT",
  "dependencies": {
    "@slack/bolt": "^3.2.0",
    "@vendia/serverless-express": "^4.10.1",
    "axios": "^1.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/node": "^18.11.9",
    "esbuild": "^0.15.14",
    "serverless": "^3.24.1",
    "serverless-esbuild": "^1.33.2",
    "serverless-offline": "^6.9.0",
    "typescript": "^4.9.3"
  }
}
